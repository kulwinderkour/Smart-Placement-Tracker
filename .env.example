# ── Database ──────────────────────────────
DB_NAME=placement_tracker
DB_USER=postgres
DB_PASS=changeme

# ── Auth ──────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth ───────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
# LOCAL DEV:
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
# PRODUCTION (Cloud Run URL):
# GOOGLE_REDIRECT_URI=https://your-backend.run.app/api/v1/auth/google/callback

# LOCAL DEV:
FRONTEND_URL=http://localhost:3000
# PRODUCTION (Firebase Hosting URL):
# FRONTEND_URL=https://your-app.web.app
# Comma-separated allowed web origins for CORS (backend + ai-engine)
# Example: FRONTEND_URLS=https://your-app.web.app,https://your-custom-domain.com
FRONTEND_URLS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# ── AI Engine ─────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
# Service URLs used by ai-engine tools
BACKEND_URL=http://backend-api:8000
EXPRESS_BACKEND_URL=http://node-scraper:8081

# ── Google Cloud Storage (resume uploads) ─
# Create a GCS bucket and set these values.
# Download a service account JSON key and set GOOGLE_APPLICATION_CREDENTIALS
# to its file path (local dev) or mount via Secret Manager (Cloud Run).
GCS_BUCKET_NAME=your-bucket-name
GCS_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Redis (Upstash — free tier) ────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Frontend ──────────────────────────────
# LOCAL DEV:
VITE_API_URL=http://localhost:8000/api/v1
# PRODUCTION:
# VITE_API_URL=https://your-backend.run.app/api/v1

# ── Scraping ──────────────────────────────
# Uses backend scraper cache via /api/jobs

