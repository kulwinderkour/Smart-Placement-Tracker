# ═══════════════════════════════════════════════════════════════════════════════
# Smart Placement Tracker - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# 
# INSTRUCTIONS FOR YOUR FRIEND:
# 1. Copy this file: cp .env.example .env
# 2. Fill in ALL required values (marked with REQUIRED)
# 3. Generate secrets using commands shown below
# 4. Place GCP service account key at: ./secrets/gcp-sa.json
# 5. Never commit .env to git (it's already in .gitignore)
#
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION (REQUIRED - Choose ONE option)
# ═══════════════════════════════════════════════════════════════════════════════

# ── Option A: Local PostgreSQL (Docker) ────────────────────────────────────────
# Use this for standalone local development
# DB_NAME=placement_tracker
# DB_USER=postgres
# DB_PASS=changeme
# DB_HOST=postgres
# DB_PORT=5432
# DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/placement_tracker
# REDIS_URL=redis://redis:6379/0

# ── Option B: Google Cloud SQL (Team Shared Database) ──────────────────────────
# Use this to connect to the shared cloud database (requires cloud-sql-proxy)
# DB_USER=placement_user
# DB_PASSWORD=ask-team-lead-for-password
# DB_NAME=placement_tracker
# DB_HOST=host.docker.internal  # or 192.168.65.254 on Mac Docker Desktop
# DB_PORT=5433  # cloud-sql-proxy port
# DATABASE_URL=postgresql+asyncpg://placement_user:PASSWORD@host.docker.internal:5433/placement_tracker
# REDIS_URL=redis://redis:6379/0  # Local Redis still used for caching

# ── Option C: Using cloud-sql-proxy (Recommended for team development) ─────────
# 1. Download cloud-sql-proxy from https://cloud.google.com/sql/docs/postgres/connect-auth-proxy
# 2. Get service account key from team lead
# 3. Run: ./cloud-sql-proxy --port 5433 PROJECT:REGION:INSTANCE
# 4. Use these settings:
DB_USER=postgres
DB_PASS=your-db-password
DB_NAME=placement_tracker
DB_HOST=host.docker.internal
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:your-db-password@host.docker.internal:5432/placement_tracker

# ═══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION & SECURITY (REQUIRED)
# ═══════════════════════════════════════════════════════════════════════════════

# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ═══════════════════════════════════════════════════════════════════════════════
# GOOGLE OAUTH (REQUIRED for Google login)
# Get from: https://console.cloud.google.com/apis/credentials
# ═══════════════════════════════════════════════════════════════════════════════
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# ═══════════════════════════════════════════════════════════════════════════════
# AI SERVICES (REQUIRED for resume parsing and job matching)
# Get Gemini API key from: https://ai.google.dev/
# OpenAI is optional (fallback)
# ═══════════════════════════════════════════════════════════════════════════════
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=sk-your-openai-key-here  # Optional fallback

# AI Engine internal service URLs (for Docker networking)
BACKEND_URL=http://backend-api:8000
EXPRESS_BACKEND_URL=http://node-scraper:8081

# ═══════════════════════════════════════════════════════════════════════════════
# GOOGLE CLOUD STORAGE (REQUIRED for resume uploads)
# ═══════════════════════════════════════════════════════════════════════════════
# 1. Create bucket at: https://console.cloud.google.com/storage
# 2. Create service account with "Storage Object Admin" role
# 3. Download JSON key and place at: ./secrets/gcp-sa.json
# 4. Set GOOGLE_APPLICATION_CREDENTIALS to point to the mounted path in container
GCS_BUCKET_NAME=your-resume-bucket-name
GCS_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json

# ═══════════════════════════════════════════════════════════════════════════════
# REDIS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Local Redis (Docker) - default for local dev
REDIS_URL=redis://redis:6379/0

# OR Upstash Redis (cloud) - for production/shared cache
# Get from: https://upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════════
# FRONTEND CONFIGURATION (REQUIRED)
# ═══════════════════════════════════════════════════════════════════════════════
VITE_API_URL=http://localhost:8000/api/v1
VITE_AI_URL=http://localhost:8002
VITE_SCRAPER_URL=http://localhost:8081/api

# RapidAPI for job scraping (optional)
VITE_RAPIDAPI_KEY=your-rapidapi-key
VITE_RAPIDAPI_URL=https://jsearch.p.rapidapi.com
VITE_API_SCRAPER_URL=http://localhost:8081/api

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: AWS S3 (alternative to GCS)
# ═══════════════════════════════════════════════════════════════════════════════
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=placement-tracker-resumes
AWS_REGION=ap-south-1

# ═══════════════════════════════════════════════════════════════════════════════
# SCRAPING CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
AI_ENGINE_URL=http://ai-engine:8002
SCRAPE_INTERVAL_MINUTES=60
MAX_JOBS_PER_RUN=100
